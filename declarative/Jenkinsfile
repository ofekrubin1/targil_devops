def files = ['a', 'b', 'c', 'd']
def teamList = ['ofekrubin1996@gmail.com', 'poodelnoodel1@gmail.com']
def mailRecipients = teamList.join(', ')

pipeline {
    agent { label 'zip-job-docker' }

    environment {
        ZIP_JOB_IMAGE = 'zip_job_image:latest'
        ZIP_JOB_DOCKER_LABEL = 'zip-job-docker'
        ARTIFACTORY_ID = 'artifactory-server'
        PYTHON_SCRIPT = 'zip_job.py'
        ARTIFACTORY_REPO = 'generic-local'
        PYTHON_CMD = 'python3'
        VERSION = '1.2.0'
        TIMESTAMP = "${new Date().format('yyyyMMdd_HHmmss', TimeZone.getTimeZone('GMT+2'))}"
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    def gitVars = checkout scm
                    echo "Checking out from: ${gitVars.GIT_URL}"
                }
            }
        }

        stage('Docker Work') {
            agent {
                docker { 
                    image "${env.ZIP_JOB_IMAGE}"
                    label "${env.ZIP_JOB_DOCKER_LABEL}"
                    reuseNode true
                    args '--privileged'
                }
            }
            stages {
                stage('Build') {
                    steps {
                        echo "Running build..."
                        sh "${env.PYTHON_CMD} ${env.PYTHON_SCRIPT}"
                    }
                }

                stage('Publish') {
                    steps {
                        script {
                            def server = Artifactory.server(env.ARTIFACTORY_ID)
                            
                            files.each { file ->
                                def fileName = "${file}_${env.VERSION}.zip"
                                
                                if (fileExists(fileName)) {
                                    def uploadSpec = """{
                                        "files": [
                                            {
                                                "pattern": "${fileName}",
                                                "target": "${env.ARTIFACTORY_REPO}/${env.TIMESTAMP}/",
                                                "flat": "true"
                                            }
                                        ]
                                    }"""
                                    server.upload(uploadSpec)
                                    echo "Uploaded: ${fileName}"
                                } else {
                                    error "Missing artifact: ${fileName}"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    
    post {
        always {
            emailext(
                subject: "Build ${currentBuild.result}: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
                body: "Check console output at: ${env.BUILD_URL}",
                to: mailRecipients
            )

            deleteDir()
        }
    }
}