def files = ['a', 'b', 'c', 'd']
def teamList = ['ofekrubin1996@gmail.com', 'poodelnoodel1@gmail.com']
def mailRecipients = teamList.join(', ')

pipeline {
    agent { label 'zip-job-docker' }

    environment {
        ZIP_JOB_IMAGE = 'zip_job_image:test'
        ZIP_JOB_DOCKER_LABEL = 'zip-job-docker'
        ARTIFACTORY_ID = 'artifactory-server'
        PYTHON_SCRIPT_LOCATION = '/tmp/zip_job.py'
        ARTIFACTORY_REPO = 'generic-local'
        PYTHON_CMD = 'python3'
        VERSION = '1.2.0'
        TIMESTAMP = "${new Date().format('yyyyMMdd_HHmmss', TimeZone.getTimeZone('GMT+2'))}"
        TYPE = 'declarative'
    }

    stages {
        stage('Build and Publish') {
            agent {
                docker { 
                    image "${env.ZIP_JOB_IMAGE}"
                    label "${env.ZIP_JOB_DOCKER_LABEL}"
                    reuseNode true
                    args '--privileged'
                }
            }
            steps {
                script {

                    echo "--- Verifying Container Environment ---"
                    sh "echo 'Operating System:' \$(uname -s) \$(uname -m)"
                    sh "[ -e /tmp/zip_job.py ] && echo '/tmp/zip_job.py exists' || echo 'ERROR: File missing!'"

                    // --- SECTION: BUILD ---
                    echo "-------------------------------------------"
                    echo "STAGE: BUILD"
                    echo "-------------------------------------------"
                    sh "${env.PYTHON_CMD} ${env.PYTHON_SCRIPT_LOCATION}"

                    // --- SECTION: PUBLISH ---
                    echo "-------------------------------------------"
                    echo "STAGE: PUBLISH"
                    echo "-------------------------------------------"
                    def server = Artifactory.server(env.ARTIFACTORY_ID)
                    
                    files.each { file ->
                        def fileName = "${file}_${env.VERSION}.zip"
                        
                        if (fileExists(fileName)) {
                            def uploadSpec = """{
                                "files": [
                                    {
                                        "pattern": "${fileName}",
                                        "target": "${env.ARTIFACTORY_REPO}/${env.TYPE}/${env.TIMESTAMP}/",
                                        "flat": "true"
                                    }
                                ]
                            }"""
                            server.upload(uploadSpec)
                            echo "Uploaded: ${fileName}"
                        } else {
                            // This triggers the 'failure' block below
                            error "Missing artifact: ${fileName}"
                        }
                    }
                }
            }
        }
    }
    
    post {
        failure {
            echo "Build failed: The pipeline has collapsed."
        }
        always {
            emailext(
                subject: "Build ${currentBuild.result}: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
                body: "Check console output at: ${env.BUILD_URL}",
                to: mailRecipients
            )

            deleteDir()
        }
    }
}