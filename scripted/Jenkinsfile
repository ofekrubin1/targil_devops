node('zip-job-docker') {
  try {
    
    def zipJobImage = 'zip_job_image:latest'
    def gitVars

    stage('Checkout') {
        gitVars = checkout scm
        echo "repo cloned ${gitVars.GIT_URL}"
        sh 'ls -la'
    }
    stage('Build') {
        docker.image(zipJobImage).inside {
            echo "Successfully running inside the container!"
            sh 'python3 zip_job.py'
            sh 'ls -la'
        }
    }
    stage('Publish') {
        sh 'ls -la'
        def server = Artifactory.server('artifactory-tlv')
        def uploadSpec = """{
          "files": [
            {
              "pattern": "*.zip",
              "target": "generic-local/"
            }
          ]
        }"""
        server.upload(uploadSpec)
    }
  } catch (err) {
      echo "Build failed: ${err}"
      currentBuild.result = 'FAILURE'
  } finally {
    stage('Cleanup') {
        deleteDir()
        sh 'rm -rf "${WORKSPACE}@tmp"'
    }
  }
}