timestamps{
  node('zip-job-docker') {
    
    def zipJobImage = 'zip_job_image:latest'
    def gitVars
    def artifactoryID = 'artifactory-server'
    def pythonScriptLocation = '/tmp/zip_job.py'
    def artifactoryRepo = 'generic-local'
    def pythonCommand = 'python3'
    def version = '1.2.0'
    def files = ['a', 'b', 'c', 'd']

    def timestamp = new Date().format("yyyyMMdd_HHmmss", TimeZone.getTimeZone('GMT+2'))

    //emails list
    def teamList = ['ofekrubin1996@gmail.com', 'poodelnoodel1@gmail.com']
    def mailRecipients = teamList.join(', ')

    try {
      //stage('Checkout') {
      //  gitVars = checkout scm
      //  echo "repo cloned ${gitVars.GIT_URL}"
      //  sh "ls -la"
      //}
      docker.image(zipJobImage).inside("--privileged") {
        stage('Build') {
        echo "Successfully running inside the container!"
        sh "${pythonCommand} ${pythonScriptLocation}"
        sh "ls -la"
        }
        stage('Publish') {
          def server = Artifactory.server(artifactoryID)
          files.each { file ->
            def fileName = "${file}_${version}.zip"
            if (fileExists(fileName)) {
              def uploadSpec = """{
                "files": [
                  {
                    "pattern": "${fileName}",
                    "target": "${artifactoryRepo}/${timestamp}/"
                  }
                ]
              }"""
              server.upload(uploadSpec)
              echo "Artifact ${fileName} successfully uploaded to Artifactory!"
            } else {
              error "File not found: ${fileName}. Check the Build stage logs!"
            }
          }
          currentBuild.result = 'SUCCESS'
        }
      }
    } 
    
    catch (err) {
        echo "Build failed: ${err}"
        currentBuild.result = 'FAILURE'
    } 
    
    finally {
      stage ('Report') {
        emailext(
        subject: "Build ${currentBuild.result}: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
        body: "Check console output at: ${env.BUILD_URL}",
        to: mailRecipients
        )
      }
        stage('Cleanup') {
        deleteDir()
        echo "workspace cleaned!"
      }
    }
  }
}