node('zip-job-docker') {

    stage('Preparation') {
        // Now Jenkins finds 'docker' and can run your image
        docker.image('zip_job_image:latest').inside {
            sh 'ls -la'
            echo "Successfully running inside the container!"
        }
    }

    stage('Checkout') {
        checkout scm
        echo "repo cloned ${env.GIT_URL}"
    }

    stage('Build') {
        sh '''
        echo "Running zip job..."
        python3 zip_job.py
        '''
        sh '''
        ls -la
        '''
    }

    stage('Publish') {

        def server = Artifactory.server('artifactory-server')

        def uploadSpec = """{
          "files": [
            {
              "pattern": "*.zip",
              "target": "generic-local/"
            }
          ]
        }"""

        server.upload(uploadSpec)
    }
}
