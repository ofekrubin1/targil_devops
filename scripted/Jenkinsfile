timestamps{
  node('zip-job-docker') {
    def type = 'scripted'
    def zipJobImage = 'zip_job_image:latest'
    def artifactoryID = 'artifactory-server'
    def pythonScriptLocation = '/tmp/zip_job.py'
    def artifactoryRepo = 'generic-local'
    def pythonCommand = 'python3'
    def version = '1.2.0'
    def files = ['a', 'b', 'c', 'd']

    def timestamp = new Date().format("yyyyMMdd_HHmmss", TimeZone.getTimeZone('GMT+2'))

    //emails list
    def teamList = ['ofekrubin1996@gmail.com', 'poodelnoodel1@gmail.com']
    def mailRecipients = teamList.join(', ')

    try {
        
        docker.image(zipJobImage).inside("-v /var/run/docker.sock:/var/run/docker.sock --privileged --user=root") {
            stage('Build') {
                echo "Successfully running inside the container!"
                def rc = sh(returnStatus: true, script: "${pythonCommand} ${pythonScriptLocation} && ls -la")
                if (rc != 0) {
                    error "Python script failed with exit code ${rc}"
                } else {
                    println "build was successfull, exit code ${rc}"
                }
            }
            stage('Publish') {
                def artifactory_server = Artifactory.server(artifactoryID)
	            def build_info = Artifactory.newBuildInfo()
                files.each { file ->
                    def fileName = "${file}_${version}.zip"
                    if (fileExists(fileName)) {
                        def uploadSpec = """{
                        "files": [
                          {
                            "pattern": "${fileName}",
                            "target": "${artifactoryRepo}/${type}/${timestamp}/"
                          }
                        ]
                        }"""
		                artifactory_server.upload(uploadSpec,build_info)
		                artifactory_server.publishBuildInfo(build_info)
                        echo "Uploaded: ${fileName}"
                    } else {
                      error "File not found: ${fileName}"
                    }
                }
            currentBuild.result = 'SUCCESS'
            }
        }
    }
    catch (err) {
        echo "Build failed: ${err}"
        currentBuild.result = 'FAILURE'
    } 
    
    finally {
        stage ('Report') {
            emailext(
            subject: "Build ${currentBuild.result}: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
            body: "Check console output at: ${env.BUILD_URL}",
            to: mailRecipients
            )
        }
        stage ('Clean Workspace') {
            println "🧹 Cleaning workspace..."
            cleanWs()
		    ws(pwd()+"@tmp"){
		    	cleanWs()
		    }
        }
    }
  }
}