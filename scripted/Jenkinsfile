node('zip-job-docker') {

    stage('Checkout') {
        checkout scm
    }

    stage('Build') {
        sh '''
        echo "Running zip job..."
        python3 zip_job.py
        '''
    }

    stage('Publish') {

        def server = Artifactory.server('artifactory-server')

        def uploadSpec = """{
          "files": [
            {
              "pattern": "*.zip",
              "target": "generic-local/"
            }
          ]
        }"""

        server.upload(uploadSpec)
    }
}
