node('zip-job-docker') {
    // 1. Locate the tool you defined in the UI
    def dockerTool = tool name: 'docker-latest'
    
    // 2. Add that tool's bin folder to the PATH
    withEnv(["PATH+DOCKER=${dockerTool}/bin"]) {
        
        stage('Preparation') {
            // Now Jenkins finds 'docker' and can run your image
            docker.image('zip_job_docker:latest').inside {
                sh 'ls -la'
                echo "Successfully running inside the container!"
            }
        }
    }

    stage('Checkout') {
        checkout scm
        echo "repo cloned ${env.GIT_URL}"
    }

    stage('Build') {
        sh '''
        echo "Running zip job..."
        python3 zip_job.py
        '''
        sh '''
        ls -la
        '''
    }

    stage('Publish') {

        def server = Artifactory.server('artifactory-server')

        def uploadSpec = """{
          "files": [
            {
              "pattern": "*.zip",
              "target": "generic-local/"
            }
          ]
        }"""

        server.upload(uploadSpec)
    }
}
