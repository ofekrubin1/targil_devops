timestamps{

  node('zip-job-docker') {
    try {
      def zipJobImage = 'zip_job_image:latest'
      def gitVars
      def artifactoryID = 'artifactory-tlv'
      def pythonScript = 'zip_job.py'
      def artifactoryRepo = 'generic-local'

      stage('Checkout') {
        gitVars = checkout scm
        echo "repo cloned ${gitVars.GIT_URL}"
        sh "ls -la"
      }
      stage('Build') {
          docker.image(zipJobImage).inside {
            echo "Successfully running inside the container!"
            sh "python3 ${pythonScript}"
            sh "ls -la"
          }
      }
      stage('Publish') {
        sh "ls -la"
        def server = Artifactory.server(artifactoryID)
        def uploadSpec = """{
          "files": [
            {
              "pattern": "*.zip",
              "target": "${artifactoryRepo}/"
            }
          ]
        }"""
        server.upload(uploadSpec)
        echo "Artifact uploaded successfully to Artifactory!"
        currentBuild.result = 'SUCCESS'
      }
    } 
    
    catch (err) {
        echo "Build failed: ${err}"
        currentBuild.result = 'FAILURE'
    } 
    
    finally {
      stage('Cleanup') {
        deleteDir()
      }
      stage ('Send Notification') {
        def result = currentBuild.result ?: 'SUCCESS' //if result is null, set it to SUCCESS
        if (result == 'SUCCESS') {
          emailext(
              subject: "Build Successful",
              body: "Your scripted pipeline build succeeded. Good job!",
              to: "ofekrubin1996@gmail.com",
              recipientProviders: [requestor(), developers(), culprits()]
          )
        } else if (result == 'FAILURE') {
          emailext(
              subject: "Build Failed",
              body: "Your scripted pipeline build failed. Please check the logs.",
              to: "ofekrubin1996@gmail.com",
              recipientProviders: [requestor(), developers(), culprits()]
          )
        }
      }
    }
  }
}